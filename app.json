{
  "expo": {
    "name": "ridetrace-app",
    "slug": "ridetrace-app",
    "scheme": "ridetrace",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#081112"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RideTrace 需要您的位置来记录骑行轨迹",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "RideTrace 需要后台位置权限以在骑行时持续记录轨迹"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#081112",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "RideTrace 需要后台位置权限以在骑行时持续记录轨迹",
          "locationWhenInUsePermission": "RideTrace 需要您的位置来记录骑行轨迹"
        }
      ]
    ]
  }
}
